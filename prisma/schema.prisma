generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String             @id @default(cuid())
  userType              UserType
  status                VerificationStatus @default(PENDING)
  email                 String             @unique
  passwordHash          String
  joinedAt              DateTime           @default(now())
  lastActive            DateTime?
  tid                   String?
  tidRecord             Tid?
  verificationsGiven    VerificationLog[]  @relation("AdminVerifications")
  verificationsReceived VerificationLog[]  @relation("UserVerifications")
  contentsCreated       Content[]          @relation("UserContent")
  flagsSubmitted        Flag[]             @relation("UserFlags")
  moderationsExecuted   ModerationLog[]    @relation("AdminModerations")
  suspendUntil DateTime
}

model Tid {
  uid     String   @id
  prefix  Prefix
  created DateTime @default(now())
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id])
}

model VerificationLog {
  id                 String             @id @default(cuid())
  userId             String
  adminId            String
  verifiedAt         DateTime           @default(now())
  verificationStatus VerificationStatus
  notes              String?
  admin              User               @relation("AdminVerifications", fields: [adminId], references: [id])
  user               User               @relation("UserVerifications", fields: [userId], references: [id], onDelete: Cascade)
}

model Content {
  id             String         @id @default(cuid()) // Unique identifier for the piece of content
  userId         String         // ID of the user who posted it
  type           ContentType    // Enforces enum: VIDEO, MESSAGE, PROFILE
  referenceUrl   String?        // Reference URL or identifier
  status         ContentStatus  @default(ACTIVE) // Enforces enum: ACTIVE, REMOVED, UNDER_REVIEW
  createdAt      DateTime       @default(now())

  // Relations
  user           User           @relation("UserContent", fields: [userId], references: [id], onDelete: Cascade)
  flags          Flag[]         // A single piece of content can have multiple flags
  moderationLogs ModerationLog[] // Tracks all administrative actions taken on this content
}

model Flag {
  id          String   @id @default(cuid())
  contentId   String   // Which content was flagged
  reportedBy  String   // Who flagged it (userId)
  reason      String   // Reason for the flag
  createdAt   DateTime @default(now()) // When it was flagged

  // Relations
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  reporter    User     @relation("UserFlags", fields: [reportedBy], references: [id], onDelete: Cascade)
}

model ModerationLog {
  id         String           @id @default(cuid())
  contentId  String           // Which content was acted on
  adminId    String           // Which admin took action
  action     ModerationAction // Enforces enum: APPROVED, REMOVED, WARNED
  createdAt  DateTime         @default(now()) // When it happened
  notes      String?          // Administrative justification notes

  // Relations
  content    Content          @relation(fields: [contentId], references: [id], onDelete: Cascade)
  admin      User             @relation("AdminModerations", fields: [adminId], references: [id])
}

enum UserType {
  ATHLETE
  SCOUT
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum Prefix {
  ATH
  SCT
}

enum ContentType {
  VIDEO
  MESSAGE
  PROFILE
}

enum ContentStatus {
  ACTIVE
  REMOVED
  UNDER_REVIEW
}

enum ModerationAction {
  APPROVED
  REMOVED
  WARNED
}