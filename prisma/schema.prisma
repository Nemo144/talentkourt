generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String             @id @default(cuid())
  userType              UserType
  status                VerificationStatus @default(PENDING)
  email                 String             @unique
  passwordHash          String
  joinedAt              DateTime           @default(now())
  lastActive            DateTime?
  tid                   String?
  tidRecord             Tid?
  verificationsGiven    VerificationLog[]  @relation("AdminVerifications")
  verificationsReceived VerificationLog[]  @relation("UserVerifications")
}

model Tid {
  uid     String   @id
  prefix  Prefix
  created DateTime @default(now())
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id])
}

model VerificationLog {
  id                 String             @id @default(cuid())
  userId             String
  adminId            String
  verifiedAt         DateTime           @default(now())
  verificationStatus VerificationStatus
  notes              String?
  admin              User               @relation("AdminVerifications", fields: [adminId], references: [id])
  user               User               @relation("UserVerifications", fields: [userId], references: [id], onDelete: Cascade)
}

enum UserType {
  ATHLETE
  SCOUT
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum Prefix {
  ATH
  SCT
}
